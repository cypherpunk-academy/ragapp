# Copy to .env and fill in values. Never commit .env.
# Expo exposes only variables prefixed with EXPO_PUBLIC_ to the app bundle.

# Supabase (Auth + Postgres sync)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ragrun API (search, chat, health) — no trailing slash
EXPO_PUBLIC_RAGRUN_BASE_URL=https://your-ragrun-instance.example.com
