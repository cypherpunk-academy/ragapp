# Copy to .env and fill in values. Never commit .env.
# Expo exposes only variables prefixed with EXPO_PUBLIC_ to the app bundle.

# Supabase (Auth + Postgres sync)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — only for build scripts (seed:fetch), never bundled into the app
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ragrun API (search, chat, sync) — server root only, no /api/v1 suffix
EXPO_PUBLIC_RAGRUN_BASE_URL=https://your-ragrun-instance.example.com

# Bump after uploading new covers (yarn upload:covers) to bust RN image cache
EXPO_PUBLIC_COVER_CACHE_VERSION=5
